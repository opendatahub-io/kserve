    {
      "collapsed": false,
      "datasource": null,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "SLI Summary",
      "type": "row",
      "span": 12
    },
    {
      "datasource": "$datasource",
      "description": "Current aggregate request rate across all models in the cluster",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": false
      },
      "targets": [
        {
          "expr": "sum(rate(kserve_vllm:request_success_total{namespace=~\"$namespace\"}[5m])) or vector(0)",
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Total Request Rate",
      "type": "gauge",
      "span": 3
    },
    {
      "datasource": "$datasource",
      "description": "Percentage of inference requests resulting in errors at the gateway level. Falls back to HTTP-based error rate if gateway metrics are unavailable.",
      "fieldConfig": {
        "defaults": {
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 2,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "100 * (sum(rate(inference_objective_request_error_total{namespace=~\"$namespace\"}[5m])) / (sum(rate(inference_objective_request_total{namespace=~\"$namespace\"}[5m])) > 0)) or 100 * (sum(rate(kserve_http_requests_total{namespace=~\"$namespace\",status!=\"2xx\"}[5m])) / (sum(rate(kserve_http_requests_total{namespace=~\"$namespace\"}[5m])) > 0)) or vector(0)",
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "HTTP Error Rate",
      "type": "gauge",
      "span": 3
    },
    {
      "datasource": "$datasource",
      "description": "99th percentile end-to-end request latency across all models. Uses gateway-level latency (includes routing overhead) with vLLM fallback.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "(histogram_quantile(0.99, sum(rate(inference_objective_request_duration_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le)) >= 0) or (histogram_quantile(0.99, sum(rate(kserve_vllm:e2e_request_latency_seconds_bucket{namespace=~\"$namespace\"}[5m])) by (le)) >= 0) or vector(0)",
          "interval": "",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "E2E Latency P99",
      "type": "gauge",
      "span": 3
    },
    {
      "datasource": "$datasource",
      "description": "Total number of ready serving pods across all inference pools",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
